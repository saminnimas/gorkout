rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function isUser(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    /**
     * Friend edges may be written in the same transaction *before* the request
     * flips to "accepted". Firestore can evaluate rule checks in an order where
     * the request is still "pending", so both pending and accepted are allowed.
     * Only the receiver (toUid) can satisfy the create rules below.
     */
    function friendRequestReadyForEdges(from, to) {
      let rid = from + '_' + to;
      return exists(/databases/$(database)/documents/friendRequests/$(rid))
        && get(/databases/$(database)/documents/friendRequests/$(rid)).data.fromUid
          == from
        && get(/databases/$(database)/documents/friendRequests/$(rid)).data.toUid == to
        && get(/databases/$(database)/documents/friendRequests/$(rid)).data.status
          in ['pending', 'accepted'];
    }

    /** Doc id is always fromUid_toUid (uids do not contain "_"). */
    function friendRequestIdMatchesUser(rid, uid) {
      return rid.matches('^' + uid + '_.+')
        || rid.matches('.+_' + uid + '$');
    }

    match /usernames/{uname} {
      allow read: if signedIn();
      allow create: if signedIn()
        && request.resource.data.uid == request.auth.uid
        && !exists(/databases/$(database)/documents/usernames/$(uname));
      allow update, delete: if false;
    }

    match /users/{uid} {
      allow read: if signedIn();
      allow create: if isUser(uid);
      allow update, delete: if false;

      match /friends/{friendUid} {
        allow read: if isUser(uid);

        allow create: if signedIn()
          && friendUid != uid
          && request.resource.data.username is string
          && request.resource.data.keys().hasAll(['username', 'addedAt'])
          && (
            (
              isUser(uid)
              && friendRequestReadyForEdges(friendUid, uid)
            )
            || (
              request.auth.uid == friendUid
              && friendRequestReadyForEdges(uid, friendUid)
            )
          );

        allow update, delete: if false;
      }

      match /devices/{deviceId} {
        allow read: if isUser(uid);
        allow create, update: if isUser(uid)
          && request.resource.data.token is string;
        allow delete: if isUser(uid);
      }
    }

    match /friendRequests/{rid} {
      allow read: if signedIn()
        && (
          resource.data.fromUid == request.auth.uid
          || resource.data.toUid == request.auth.uid
          || friendRequestIdMatchesUser(rid, request.auth.uid)
        );

      allow create: if signedIn()
        && request.resource.data.fromUid == request.auth.uid
        && request.resource.data.fromUid is string
        && request.resource.data.toUid is string
        && request.resource.data.status == 'pending'
        && request.resource.data.fromUid != request.resource.data.toUid;

      allow update: if signedIn() && (
        (resource.data.status == 'pending'
          && (
            (resource.data.toUid == request.auth.uid
              && request.resource.data.status in ['accepted', 'declined'])
            || (resource.data.fromUid == request.auth.uid
              && request.resource.data.status == 'declined')
          ))
        || (resource.data.fromUid == request.auth.uid
          && resource.data.status == 'declined'
          && request.resource.data.status == 'pending')
        || (
          resource.data.status == 'accepted'
          && request.resource.data.status == 'pending'
          && request.resource.data.fromUid == resource.data.fromUid
          && request.resource.data.toUid == resource.data.toUid
          && (resource.data.fromUid == request.auth.uid
            || resource.data.toUid == request.auth.uid)
        )
      );

      allow delete: if signedIn()
        && (resource.data.fromUid == request.auth.uid
            || resource.data.toUid == request.auth.uid);
    }

    match /goals/{goalId} {
      allow read: if signedIn()
        && request.auth.uid in resource.data.participantIds;

      allow create: if signedIn()
        && request.auth.uid == request.resource.data.creatorUid
        && request.auth.uid in request.resource.data.participantIds;

      allow update: if signedIn()
        && resource.data.creatorUid == request.auth.uid
        && request.resource.data.participantIds.hasAll(resource.data.participantIds)
        && request.resource.data.participantIds.size() > resource.data.participantIds.size();
      allow delete: if false;

      match /logs/{logId} {
        allow read: if signedIn()
          && request.auth.uid in get(/databases/$(database)/documents/goals/$(goalId)).data.participantIds;
        allow create: if signedIn()
          && request.auth.uid == request.resource.data.userId
          && request.auth.uid in get(/databases/$(database)/documents/goals/$(goalId)).data.participantIds
          && request.resource.data.reps is int
          && request.resource.data.reps > 0
          && request.resource.data.userId == request.auth.uid
          && (
            request.resource.data.keys().hasOnly(['userId', 'reps', 'createdAt'])
            || request.resource.data.keys().hasOnly(['userId', 'reps', 'createdAt', 'fieldId'])
          );
        allow update, delete: if false;
      }

      match /surrenders/{userId} {
        allow read: if signedIn()
          && request.auth.uid in get(/databases/$(database)/documents/goals/$(goalId)).data.participantIds;
        allow create, update: if signedIn()
          && request.auth.uid == userId
          && request.auth.uid in get(/databases/$(database)/documents/goals/$(goalId)).data.participantIds
          && request.resource.data.keys().hasOnly(['at']);
        allow delete: if false;
      }
    }
  }
}
